# Copy to /etc/s111/s111-api.env on the Droplet.
# Use a strong password. Do not commit the real file with secrets.

S111_DB_HOST=127.0.0.1
S111_DB_PORT=5432
S111_DB_NAME=s111_verification
S111_DB_USER=s111_app
S111_DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

S111_API_CORS_ORIGIN=*
S111_API_DEFAULT_LIMIT=5000
S111_API_MAX_LIMIT=50000
